# React 프론트엔드 환경 변수 예제
#
# 사용 방법:
# 1. 이 파일을 복사하여 .env.local 또는 .env.development 파일 생성
#    cp .env.example .env.local
# 2. 아래 설정값들을 실제 값으로 변경

# ==============================================
# 백엔드 API URL
# ==============================================
# 로컬 개발 환경 (백엔드 서버가 localhost:8080에서 실행 중일 때)
VITE_API_URL=http://localhost:8080

# 원격 서버 (배포된 서버 사용 시)
# VITE_API_URL=https://your-server.com

# ==============================================
# Google Maps API 키
# ==============================================
# Google Cloud Console에서 API 키 발급 방법:
# 1. https://console.cloud.google.com/ 접속
# 2. 프로젝트 생성 또는 선택
# 3. "API 및 서비스" > "사용자 인증 정보" 메뉴 이동
# 4. "사용자 인증 정보 만들기" > "API 키" 선택
# 5. 다음 API들을 활성화:
#    - Maps JavaScript API: https://console.cloud.google.com/apis/library/maps-backend.googleapis.com
#    - Geocoding API: https://console.cloud.google.com/apis/library/geocoding-backend.googleapis.com
# 6. 발급받은 API 키를 아래에 입력

VITE_GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY_HERE

# ==============================================
# 디버그 모드 (선택사항)
# ==============================================
# WebSocket 디버깅 활성화
# VITE_WS_DEBUG=true
