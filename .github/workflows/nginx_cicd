name: Deploy JAR to Private EC2 (Self-hosted Runner + systemd)

on:
  push:
    branches: ["main"]
  workflow_dispatch:

concurrency:
  group: deploy-jar-main
  cancel-in-progress: true

jobs:
  deploy:
    runs-on: [self-hosted, linux, x64]
    timeout-minutes: 20

    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Setup JDK 17
        uses: actions/setup-java@v4
        with:
          distribution: temurin
          java-version: "17"
          cache: gradle

      - name: Build (Gradle bootJar)
        run: |
          chmod +x ./gradlew
          ./gradlew clean test bootJar

      - name: Install JAR to /opt/app/app.jar
        run: |
          set -euo pipefail
          JAR="$(ls -1 build/libs/*.jar | head -n 1)"
          echo "Using JAR: $JAR"

          sudo mkdir -p /opt/app
          sudo cp "$JAR" /opt/app/app.jar
          sudo chown root:root /opt/app/app.jar
          sudo chmod 0644 /opt/app/app.jar

      - name: Restart systemd service (myapp)
        run: |
          sudo systemctl daemon-reload
          sudo systemctl restart myapp
          sudo systemctl --no-pager --full status myapp || true

      - name: Health check
        run: |
          # actuator 사용 시
          URL="http://127.0.0.1:8080/actuator/health"
          for i in {1..30}; do
            if curl -fsS "$URL" >/dev/null; then
              echo "OK"
              exit 0
            fi
            sleep 2
          done
          echo "Health check failed"
          sudo journalctl -u myapp -n 200 --no-pager || true
          exit 1
