# docker-compose.yml이 사용하는 환경변수 목록.
# 이 파일을 .env로 복사한 뒤 실제 값을 채운다. .env는 git에 커밋하지 않는다.
#   cp .env.example .env

# MariaDB
DB_ROOT_PASSWORD=change-me-root-password
DB_NAME=senior_attendance
DB_USERNAME=senior
DB_PASSWORD=change-me-db-password

# JWT (accessToken 서명 비밀키, 32바이트 이상 권장)
JWT_SECRET=change-me-to-a-long-random-256-bit-secret

# refreshToken 해시용 비밀키 (필수, 없으면 백엔드가 기동하지 않음)
REFRESH_TOKEN_HASH_SECRET=change-me-to-a-long-random-secret

# admin-web/모바일 앱에서 오는 요청을 허용할 오리진 (콤마 구분)
# EC2에 붙는 실제 도메인/IP로 교체한다. admin-web은 nginx가 같은 오리진으로
# /api/를 프록시하므로 보통 모바일 앱 쪽 오리진만 추가하면 된다.
ALLOWED_ORIGINS=http://localhost

# 보호자 알림용 CoolSMS (미설정 시 SmsService 빈이 생성되지 않고 SMS 발송만 비활성화됨)
COOLSMS_API_KEY=
COOLSMS_API_SECRET=
COOLSMS_SENDER_NUMBER=
